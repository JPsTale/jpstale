<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jpstale.dao.userdb.mapper.CharacterInfoDeleteMapper">

    <!-- C++ accountserver.cpp:1556 - INSERT ... SELECT from CharacterInfo -->
    <insert id="insertFromCharacterInfoByName">
        INSERT INTO userdb.character_info_delete SELECT * FROM userdb.character_info WHERE name = #{name}
    </insert>

</mapper>
