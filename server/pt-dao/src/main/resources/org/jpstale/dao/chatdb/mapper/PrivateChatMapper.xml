<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jpstale.dao.chatdb.mapper.PrivateChatMapper">

    <!-- C++ ChatServer PrivateChat INSERT -->
    <insert id="insertPrivateChat" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chatdb.private_chat (sender_name, receiver_name, message, unix_time)
        VALUES (#{senderName}, #{receiverName}, #{message}, #{unixTime})
    </insert>

</mapper>
