<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jpstale.dao.chatdb.mapper.PublicChatMapper">

    <!-- C++ ChatServer PublicChat INSERT -->
    <insert id="insertPublicChat" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chatdb.public_chat (map_id, character_name, message, unix_time)
        VALUES (#{mapId}, #{characterName}, #{message}, #{unixTime})
    </insert>

</mapper>
