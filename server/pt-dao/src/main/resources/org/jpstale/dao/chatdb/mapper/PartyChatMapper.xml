<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jpstale.dao.chatdb.mapper.PartyChatMapper">

    <!-- C++ ChatServer PartyChat INSERT -->
    <insert id="insertPartyChat" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chatdb.party_chat (character_name, message, unix_time)
        VALUES (#{characterName}, #{message}, #{unixTime})
    </insert>

</mapper>
