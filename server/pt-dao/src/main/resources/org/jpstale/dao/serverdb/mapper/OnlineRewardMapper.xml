<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jpstale.dao.serverdb.mapper.OnlineRewardMapper">

    <!-- C++ eventserver.cpp:1242 - ORDER BY NEWID() -> random in PostgreSQL -->
    <select id="selectItemCodeQuantityPercentOrderByRandom" resultType="org.jpstale.dao.serverdb.entity.OnlineReward">
        SELECT item_code, quantity, percent FROM serverdb.online_reward ORDER BY RANDOM()
    </select>

</mapper>
